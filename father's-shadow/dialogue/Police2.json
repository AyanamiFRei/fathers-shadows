  "next": "pol2_common_1"
},

{
  "id": "pol2_y1",
  "type": "line",
  "name": "ПОЛИЦИЯ",
  "text": "Вспомнишь.",
  "portrait_node": "Police/Police_Base",
  "next": "pol2_y1_2"
},

{
  "id": "pol2_y1_2",
  "type": "line",
  "name": "ПОЛИЦИЯ",
  "text": "Она умеет запоминаться.",
