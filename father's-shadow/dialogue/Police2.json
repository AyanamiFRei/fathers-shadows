	  "next": "pol2_x1"
	},
	{
	  "button": "choice_y",
	  "text": "Не помню",
	  "next": "pol2_y1"
	},
	{
	  "button": "choice_b",
	  "text": "(Промолчать)",
	  "next": "pol2_b1"
