  "next": "pol2_choice_2"
},

{
  "id": "pol2_choice_2",
  "type": "choice",
  "portrait_node": "Alex/Alex_Base",
  "options": [
	{
	  "button": "choice_x",
	  "text": "Я просто вожу людей",
	  "next": "pol2_x2"
	},
	{
	  "button": "choice_y",
	  "text": "Понял",
	  "next": "pol2_y2"
	},
	{
	  "button": "choice_b",
	  "text": "Мне всё равно",
	  "next": "pol2_b2"
	}
  ]
},

{
  "id": "pol2_x2",
  "type": "line",
  "name": "ПОЛИЦИЯ",
  "text": "И продолжай так делать.",
  "portrait_node": "Police/Police_Base",
  "next": "pol2_x2_2"
},

{
  "id": "pol2_x2_2",
  "type": "line",
  "name": "ПОЛИЦИЯ",
  "text": "Без лишних вопросов.",
  "portrait_node": "Police/Police_Base",
  "next": "pol2_end"
},

{
  "id": "pol2_y2",
  "type": "line",
  "name": "ПОЛИЦИЯ",
