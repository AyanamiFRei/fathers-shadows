  "portrait_node": "Police/Police_Base",
  "next": "pol2_end"
},

{
  "id": "pol2_b2",
  "type": "line",
  "name": "ПОЛИЦИЯ",
  "text": "Это твой выбор.",
  "portrait_node": "Police/Police_Base",
  "next": "pol2_b2_2"
},

{
  "id": "pol2_b2_2",
  "type": "line",
  "name": "ПОЛИЦИЯ",
