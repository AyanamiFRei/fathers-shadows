{
  "npc_id": "leva",
  "start": "npc1_1",
  "nodes": [

{
  "id": "npc1_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Поехали… только давай побыстрее, ладно?",
  "portrait_node": "Leva/Leva_Base",
  "pause_after": 2.0,
  "next": "npc1_2"
},

{
  "id": "npc1_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Ты тут недавно работаешь? Лицо незнакомое…",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc0_choice"
},

{
  "id": "npc0_choice",
  "type": "choice",
  "portrait_node": "Alex/Alex_Base",
  "options": [
	{
	  "button": "choice_x",
	  "text": "Да! Первый день на работу вышел.",
	  "loyalty_target": "leva",
	  "loyalty_change": 15,
	  "next": "npc0_x_1"
	},
	{
	  "button": "choice_y",
	  "text": "Решил немного подзаработать.",
	  "loyalty_target": "leva",
	  "loyalty_change": 5,
	  "next": "npc0_x_1"
	},
	{
	  "button": "choice_b",
	  "text": "(Промолчать)",
	  "loyalty_target": "leva",
	  "loyalty_change": -5,
	  "next": "npc1_4"
	}
  ]
},

{
  "id": "npc0_x_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Это правильно. Времена сейчас непростые...",
  "portrait_node": "Leva/Leva_Kind",
  "next": "npc0_x_2"
},

{
  "id": "npc0_x_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Особенно в нашем районе.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_4"
},

{
  "id": "npc1_4",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Слышал же, что у нас тут недавно произошло?",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_5"
},

{
  "id": "npc1_5",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Ну, старика одного… того.",
  "portrait_node": "Leva/Leva_Base",
  "pause_after": 1.2,
  "next": "npc1_choice"
},

{
  "id": "npc1_choice",
  "type": "choice",
  "portrait_node": "Alex/Alex_Base",
  "options": [
	{
	  "button": "choice_x",
	  "text": "Какого старика?",
	  "next": "npc1_x_1"
	},
	{
	  "button": "choice_y",
	  "text": "Слышал кое-что",
	  "next": "npc1_y_1"
	},
	{
	  "button": "choice_b",
	  "text": "Мне не до этого",
	  "loyalty_target": "leva",
	  "loyalty_change": -5,
	  "next": "npc1_b_1"
	}
  ]
},

{
  "id": "npc1_x_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Серьёзно?",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_x_2"
},

{
  "id": "npc1_x_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Да весь район об этом говорит.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_x_3"
},

{
  "id": "npc1_x_3",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Фёдор Карамазов… не самый приятный тип был.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_1"
},

{
  "id": "npc1_y_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "А, ну тогда знаешь…",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_y_2"
},

{
  "id": "npc1_y_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Старик Карамазов. Говорят, его давно убрать хотели.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_1"
},

{
  "id": "npc1_b_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Ха… правильно.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_b_2"
},

{
  "id": "npc1_b_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Чем меньше знаешь — тем крепче спишь.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_1"
},

{
  "id": "npc1_common_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Но там мутная история.",
  "portrait_node": "Leva/Leva_Base",
  "pause_after": 1.0,
  "next": "npc1_common_2"
},

{
  "id": "npc1_common_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Кто-то говорит — сын его того... грохнул.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_3"
},

{
  "id": "npc1_common_3",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Кто-то — что это конкуренты по бизнесу убрать решились.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_4"
},

{
  "id": "npc1_common_4",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "А у старика конкуренты были!",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_5"
},

{
  "id": "npc1_common_5",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Всё же он делами грязными промышлял.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_6"
},

{
  "id": "npc1_common_6",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Контрабанда, деньги…",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_7"
},

{
  "id": "npc1_common_7",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Ну это, конечно, если слухам верить.",
  "portrait_node": "Leva/Leva_Base",
  "pause_after": 1.0,
  "next": "npc1_common_8"
},

{
  "id": "npc1_common_8",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Но я тебе честно скажу.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_9"
},

{
  "id": "npc1_common_9",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "В нашем районе лучше быть начеку.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_common_10"
},

{
  "id": "npc1_common_10",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Особенно с чужими разговорами.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_acquaintance_1"
},

{
  "id": "npc1_acquaintance_1",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Кстати...",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_acquaintance_2"
},

{
  "id": "npc1_acquaintance_2",
  "type": "line",
  "name": "ПАССАЖИР",
  "text": "Меня Лёва зовут.",
  "portrait_node": "Leva/Leva_Kind",
  "next": "npc1_acquaintance_3"
},

{
  "id": "npc1_acquaintance_3",
  "type": "line",
  "name": "ЛЁВА",
  "text": "Я курьером работаю.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_acquaintance_4"
},

{
  "id": "npc1_acquaintance_4",
  "type": "line",
  "name": "ЛЁВА",
  "text": "Документы всякие вожу.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_acquaintance_5"
},

{
  "id": "npc1_acquaintance_5",
  "type": "line",
  "name": "ЛЁВА",
  "text": "...Иногда лучше не знать, какие.",
  "portrait_node": "Leva/Leva_Base",
  "pause_after": 1.5,
  "next": "npc3_choice"
},

{
  "id": "npc3_choice",
  "type": "choice",
  "portrait_node": "Alex/Alex_Base",
  "options": [
	{
	  "button": "choice_x",
	  "text": "Приму к сведению",
	  "loyalty_target": "leva",
	  "loyalty_change": 10,
	  "next": "npc3_x_1"
	},
	{
	  "button": "choice_y",
	  "text": "Я не очень разговорчив",
	  "next": "npc3_y_1"
	},
	{
	  "button": "choice_b",
	  "text": "Это не твое дело",
	  "loyalty_target": "leva",
	  "loyalty_change": -10,
	  "next": "npc3_b_1"
	}
  ]
},

{
  "id": "npc3_x_1",
  "type": "line",
  "name": "ЛЁВА",
  "text": "ПРАВИЛЬНО!!!",
  "portrait_node": "Leva/Leva_Kind",
  "next": "npc1_end_1"
},

{
  "id": "npc3_y_1",
  "type": "line",
  "name": "ЛЁВА",
  "text": "Как знаешь.",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_end_1"
},

{
  "id": "npc3_b_1",
  "type": "line",
  "name": "ЛЁВА",
  "text": "...",
  "portrait_node": "Leva/Leva_Angry",
  "next": "npc1_end_1"
},

{
  "id": "npc1_end_1",
  "type": "line",
  "name": "ЛЁВА",
  "text": "О, моя остановка...",
  "portrait_node": "Leva/Leva_Base",
  "next": "npc1_end_2"
},

{
  "id": "npc1_end_2",
  "type": "line",
  "name": "ЛЁВА",
  "text": "Ещё увидимся!",
  "portrait_node": "Leva/Leva_Kind"
}

  ]
}
